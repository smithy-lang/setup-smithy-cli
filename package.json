{
  "name": "smithy-cli-github-action",
  "version": "0.1.0",
  "description": "GitHub Action to install the Smithy CLI",
  "private": true,
  "scripts": {
    "build": "tsc",
    "test": "vitest --run",
    "package": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outdir=dist/main && esbuild src/post.ts --bundle --platform=node --target=node20 --format=cjs --outdir=dist/post"
  },
  "dependencies": {
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@actions/tool-cache": "^4.0.0",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/semver": "^7.5.8",
    "esbuild": "^0.28.0",
    "fast-check": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
